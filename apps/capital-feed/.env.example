# Capital.com API credentials
CAPITAL_API_KEY=your_api_key_here
CAPITAL_IDENTIFIER=your_email@example.com
CAPITAL_API_PASSWORD=your_password_here

# Database
DATABASE_URL=postgresql://user:password@host:port/dbname

# Symbol to track
CAPITAL_SYMBOL=NATURALGAS

# Source identifier for database
CAPITAL_SOURCE=capitalcom

# WebSocket URL (optional, defaults shown)
# CAPITAL_WS_URL=wss://api-streaming-capital.backend-capital.com/connect

# REST API URL for backfill (optional, defaults shown)
# CAPITAL_REST_URL=https://api-capital.backend-capital.com/api/v1
