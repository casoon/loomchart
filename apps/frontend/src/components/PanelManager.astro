---
// Panel Manager - Show/hide/remove panels sidebar
---

<div
  x-show="showPanelManager"
  x-cloak
  class="fixed right-0 top-16 bottom-0 w-80 bg-card border-l border-border shadow-lg z-40 flex flex-col"
>
  <!-- Header -->
  <div class="flex items-center justify-between p-4 border-b border-border">
    <h2 class="text-sm font-semibold text-foreground uppercase tracking-wide">Active Panels</h2>
    <button @click="showPanelManager = false" class="text-muted-foreground hover:text-foreground">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <!-- Panel List -->
  <div id="panel-list" class="flex-1 overflow-auto p-4 space-y-2">
    <!-- Populated dynamically -->
  </div>

  <!-- Actions -->
  <div class="p-4 border-t border-border space-y-2">
    <button
      @click="showIndicatorSelector = true"
      class="w-full px-4 py-2 bg-primary text-primary-foreground rounded-md hover:bg-primary/90 transition-colors flex items-center justify-center gap-2"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
      </svg>
      Add Indicator
    </button>

    <button
      id="reset-layout-btn"
      class="w-full px-4 py-2 bg-background border border-border text-foreground rounded-md hover:bg-accent transition-colors"
    >
      Reset Layout
    </button>
  </div>
</div>

<style>
  .panel-item {
    @apply bg-background border border-border rounded-md p-3 transition-all;
  }

  .panel-item.collapsed {
    @apply opacity-60;
  }

  .panel-item-header {
    @apply flex items-center justify-between;
  }

  .panel-item-title {
    @apply flex items-center gap-2 text-sm font-medium text-foreground;
  }

  .panel-item-controls {
    @apply flex items-center gap-1;
  }

  .panel-item-btn {
    @apply w-7 h-7 flex items-center justify-center rounded hover:bg-accent text-muted-foreground hover:text-foreground transition-colors;
  }

  .panel-item-info {
    @apply mt-2 text-xs text-muted-foreground;
  }

  .drag-handle {
    @apply cursor-move text-muted-foreground hover:text-foreground;
  }
</style>

<script>
  interface PanelInfo {
    id: string;
    title: string;
    panel_type: any;
    computed_height: number;
    collapsed?: boolean;
    order_index: number;
  }

  class PanelManagerUI {
    private sidebar: HTMLElement;
    private panelList: HTMLElement;
    private panels: PanelInfo[] = [];

    constructor() {
      this.sidebar = document.getElementById('panel-manager')!;
      this.panelList = document.getElementById('panel-list')!;

      this.setupEventListeners();
    }

    private setupEventListeners() {
      // Reset layout (Alpine.js handles close button and add indicator)
      document.getElementById('reset-layout-btn')?.addEventListener('click', async () => {
        if (confirm('Reset to default layout? This will remove all indicator panels.')) {
          await this.resetLayout();
        }
      });
    }

    // show() and hide() removed - Alpine.js handles visibility via x-show
    // refresh() is called via Alpine.js x-init or externally

    public async refresh() {
      try {
        const wasm = (window as any).getWasm?.();
        if (!wasm) return;

        const layoutJson = await wasm.get_panel_layout();
        const layout = JSON.parse(layoutJson);

        this.panels = layout.panels || [];
        this.renderPanels();
      } catch (err) {
        console.error('Failed to refresh panel list:', err);
      }
    }

    private renderPanels() {
      if (this.panels.length === 0) {
        this.panelList.innerHTML = '<div class="text-sm text-muted-foreground italic text-center py-8">No panels</div>';
        return;
      }

      this.panelList.innerHTML = this.panels.map((panel, index) => {
        const isChart = panel.panel_type.type === 'Chart';
        const isCollapsed = panel.collapsed || false;

        let typeInfo = '';
        if (isChart) {
          const overlayCount = panel.panel_type.overlays?.length || 0;
          typeInfo = overlayCount > 0 ? `${overlayCount} overlay(s)` : 'Main chart';
        } else if (panel.panel_type.type === 'Indicator') {
          typeInfo = `Indicator: ${panel.panel_type.indicator_id}`;
        }

        return `
          <div class="panel-item ${isCollapsed ? 'collapsed' : ''}" data-panel-id="${panel.id}">
            <div class="panel-item-header">
              <div class="panel-item-title">
                <svg class="drag-handle w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/>
                </svg>
                <span>${panel.title}</span>
                ${isCollapsed ? '<span class="text-xs">(Hidden)</span>' : ''}
              </div>
              <div class="panel-item-controls">
                ${this.renderControls(panel, isChart)}
              </div>
            </div>
            ${typeInfo ? `<div class="panel-item-info">${typeInfo} • ${panel.computed_height}px</div>` : ''}
          </div>
        `;
      }).join('');

      this.attachPanelHandlers();
    }

    private renderControls(panel: PanelInfo, isChart: boolean): string {
      const buttons: string[] = [];

      // Eye icon (collapse/expand)
      const eyeIcon = panel.collapsed
        ? '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>'
        : '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>';

      buttons.push(`
        <button class="panel-item-btn toggle-visibility" data-panel-id="${panel.id}" title="${panel.collapsed ? 'Show' : 'Hide'} Panel">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            ${eyeIcon}
          </svg>
        </button>
      `);

      // Settings
      buttons.push(`
        <button class="panel-item-btn panel-settings" data-panel-id="${panel.id}" title="Panel Settings">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </button>
      `);

      // Remove (not for main chart)
      if (!isChart) {
        buttons.push(`
          <button class="panel-item-btn remove-panel" data-panel-id="${panel.id}" title="Remove Panel">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
          </button>
        `);
      }

      return buttons.join('');
    }

    private attachPanelHandlers() {
      // Toggle visibility
      this.panelList.querySelectorAll('.toggle-visibility').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const panelId = (btn as HTMLElement).dataset.panelId!;
          await this.togglePanelVisibility(panelId);
        });
      });

      // Remove panel
      this.panelList.querySelectorAll('.remove-panel').forEach(btn => {
        btn.addEventListener('click', async (e) => {
          const panelId = (btn as HTMLElement).dataset.panelId!;
          const panel = this.panels.find(p => p.id === panelId);
          if (panel && confirm(`Remove panel "${panel.title}"?`)) {
            await this.removePanel(panelId);
          }
        });
      });

      // Settings
      this.panelList.querySelectorAll('.panel-settings').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const panelId = (btn as HTMLElement).dataset.panelId!;
          this.showPanelSettings(panelId);
        });
      });

      // Drag & drop for reordering (simplified)
      this.panelList.querySelectorAll('.drag-handle').forEach(handle => {
        handle.addEventListener('mousedown', (e) => {
          // TODO: Implement drag & drop reordering
          console.log('Drag to reorder - TODO');
        });
      });
    }

    private async togglePanelVisibility(panelId: string) {
      try {
        const wasm = (window as any).getWasm?.();
        if (!wasm) return;

        // TODO: Implement collapse/expand in WASM
        // For now, just refresh
        console.log('Toggle visibility:', panelId);
        await this.refresh();
      } catch (err) {
        console.error('Failed to toggle panel:', err);
      }
    }

    private async removePanel(panelId: string) {
      try {
        const wasm = (window as any).getWasm?.();
        if (!wasm) return;

        await wasm.remove_panel(panelId);
        (window as any).refreshPanels?.();
        await this.refresh();
      } catch (err) {
        console.error('Failed to remove panel:', err);
        alert('Failed to remove panel');
      }
    }

    private showPanelSettings(panelId: string) {
      const panel = this.panels.find(p => p.id === panelId);
      if (!panel) return;

      console.log('Show settings for:', panel.title);
      // TODO: Implement settings modal
      alert(`Settings for ${panel.title}\n\nComing soon:\n- Indicator parameters\n- Colors\n- Scale options`);
    }

    private async resetLayout() {
      try {
        const wasm = (window as any).getWasm?.();
        if (!wasm) return;

        // Remove all non-chart panels
        for (const panel of this.panels) {
          if (panel.panel_type.type !== 'Chart') {
            await wasm.remove_panel(panel.id);
          }
        }

        (window as any).refreshPanels?.();
        await this.refresh();
      } catch (err) {
        console.error('Failed to reset layout:', err);
        alert('Failed to reset layout');
      }
    }
  }

  // Initialize and expose refresh function
  if (typeof window !== 'undefined') {
    document.addEventListener('DOMContentLoaded', () => {
      const panelManagerUI = new PanelManagerUI();

      // Expose refresh globally for external calls
      (window as any).refreshPanelManager = () => panelManagerUI.refresh();
    });
  }
</script>
