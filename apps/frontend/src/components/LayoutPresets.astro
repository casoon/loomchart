---
// Layout Presets Component
// Task 6.2: Quick-apply predefined layout templates
---

<div
  x-data="layoutPresets()"
  x-init="init()"
  x-show="$store.layoutPresetsOpen"
  @click.self="close()"
  class="fixed inset-0 z-50 flex items-center justify-center bg-background/80 backdrop-blur-sm"
  x-cloak
>
  <div
    @click.stop
    class="relative w-full max-w-4xl max-h-[85vh] bg-card border border-border rounded-lg shadow-lg overflow-hidden flex flex-col"
  >
    <!-- Header -->
    <div class="flex items-center justify-between px-6 py-4 border-b border-border">
      <div>
        <h2 class="text-lg font-semibold text-foreground">Layout Presets</h2>
        <p class="text-sm text-muted-foreground mt-0.5">Quick-apply predefined trading layouts</p>
      </div>
      <button
        @click="close()"
        class="text-muted-foreground hover:text-foreground transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Category Tabs -->
    <div class="flex border-b border-border bg-muted/30">
      <button
        @click="selectedCategory = 'simple'"
        :class="selectedCategory === 'simple' ? 'border-primary text-primary' : 'border-transparent text-muted-foreground hover:text-foreground'"
        class="px-6 py-3 text-sm font-medium border-b-2 transition-colors"
      >
        Simple
      </button>
      <button
        @click="selectedCategory = 'technical'"
        :class="selectedCategory === 'technical' ? 'border-primary text-primary' : 'border-transparent text-muted-foreground hover:text-foreground'"
        class="px-6 py-3 text-sm font-medium border-b-2 transition-colors"
      >
        Technical
      </button>
      <button
        @click="selectedCategory = 'advanced'"
        :class="selectedCategory === 'advanced' ? 'border-primary text-primary' : 'border-transparent text-muted-foreground hover:text-foreground'"
        class="px-6 py-3 text-sm font-medium border-b-2 transition-colors"
      >
        Advanced
      </button>
    </div>

    <!-- Content -->
    <div class="flex-1 overflow-y-auto px-6 py-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <template x-for="preset in filteredPresets" :key="preset.id">
          <div
            @click="applyPreset(preset.id)"
            class="bg-background border-2 border-border rounded-lg p-4 cursor-pointer hover:border-primary hover:shadow-md transition-all group"
          >
            <!-- Icon -->
            <div class="flex items-center justify-center w-12 h-12 bg-primary/10 rounded-lg mb-3 group-hover:bg-primary/20 transition-colors">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" :d="preset.icon"></path>
              </svg>
            </div>

            <!-- Name & Description -->
            <h3 class="font-semibold text-foreground mb-1" x-text="preset.name"></h3>
            <p class="text-xs text-muted-foreground leading-relaxed" x-text="preset.description"></p>

            <!-- Panel Count -->
            <div class="mt-3 pt-3 border-t border-border">
              <span class="text-xs text-muted-foreground">
                <span x-text="preset.panels.length"></span> panel<span x-show="preset.panels.length !== 1">s</span>
              </span>
            </div>
          </div>
        </template>
      </div>

      <!-- Empty State -->
      <template x-if="filteredPresets.length === 0">
        <div class="text-center py-12 text-muted-foreground">
          <p>No presets available in this category.</p>
        </div>
      </template>
    </div>

    <!-- Footer -->
    <div class="flex items-center justify-between px-6 py-4 border-t border-border bg-muted/30">
      <div class="text-sm text-muted-foreground">
        <span x-text="filteredPresets.length"></span> preset<span x-show="filteredPresets.length !== 1">s</span> available
      </div>
      <button
        @click="close()"
        class="px-4 py-2 bg-secondary text-secondary-foreground rounded-md text-sm font-medium hover:bg-secondary/80 transition-colors"
      >
        Close
      </button>
    </div>
  </div>
</div>

<script>
  import { LAYOUT_PRESETS, getPresetsByCategory, applyPreset } from '../lib/layout-presets';
  import Alpine from 'alpinejs';

  function layoutPresets() {
    return {
      selectedCategory: 'simple' as 'simple' | 'technical' | 'advanced',
      presets: LAYOUT_PRESETS,

      init() {
        // Initialize
      },

      get filteredPresets() {
        return getPresetsByCategory(this.selectedCategory);
      },

      async applyPreset(presetId: string) {
        try {
          const preset = this.presets.find((p) => p.id === presetId);
          if (!preset) {
            throw new Error('Preset not found');
          }

          // Confirm before applying
          if (!confirm(`Apply "${preset.name}" layout? This will replace your current panels.`)) {
            return;
          }

          const success = await applyPreset(presetId);

          if (success) {
            (window as any).showToast?.('success', `Applied "${preset.name}" layout`);
            this.close();
          } else {
            throw new Error('Failed to apply preset');
          }
        } catch (err) {
          console.error('Failed to apply preset:', err);
          (window as any).showToast?.('error', 'Failed to apply layout preset');
        }
      },

      close() {
        Alpine.store('layoutPresetsOpen', false);
      },
    };
  }

  // Register Alpine component
  if (typeof window !== 'undefined') {
    Alpine.data('layoutPresets', layoutPresets);
  }
</script>

<style>
  [x-cloak] {
    display: none !important;
  }
</style>
