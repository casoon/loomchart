---
// Error display component
interface Props {
  title?: string;
  message?: string;
  retryable?: boolean;
}

const {
  title = 'Error',
  message = 'Something went wrong',
  retryable = true
} = Astro.props;
---

<div class="flex flex-col items-center justify-center gap-4 p-6 text-center">
  <div class="w-12 h-12 rounded-full bg-error/10 flex items-center justify-center">
    <svg class="w-6 h-6 text-error" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
    </svg>
  </div>
  <div>
    <h3 class="font-semibold text-primary">{title}</h3>
    <p class="text-secondary text-sm mt-1">{message}</p>
  </div>
  {retryable && (
    <button
      x-on:click="window.location.reload()"
      class="px-4 py-2 bg-accent hover:bg-accent/80 text-white rounded text-sm transition-colors"
    >
      Retry
    </button>
  )}
</div>

<style>
  .text-error {
    color: rgb(239, 68, 68);
  }
  .bg-error\/10 {
    background-color: rgba(239, 68, 68, 0.1);
  }
</style>
