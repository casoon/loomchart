{
  "name": "loom",
  "version": "0.1.0",
  "private": true,
  "description": "Realtime Trading UI - Monorepo",
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm run build:packages && pnpm --filter @loom/frontend run dev",
    "build": "pnpm -r run build",
    "build:packages": "pnpm --filter @loom/shared --filter @loom/chart-core --filter @loom/chart-wrapper run build",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "wasm:build": "pnpm --filter @loom/wasm-core run build",
    "phoenix:setup": "cd apps/phoenix && mix deps.get && mix ecto.setup",
    "phoenix:dev": "cd apps/phoenix && mix phx.server",
    "db:migrate": "cd apps/phoenix && mix ecto.migrate"
  },
  "devDependencies": {
    "@casoon/nosecrets": "^0.3.7",
    "@types/node": "^20.10.0",
    "husky": "^9.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
